# Front UPi (NAPSI) — copie para .env e ajuste só na sua máquina:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/macOS)
#
# Nenhum script do repositório cria, apaga ou sobrescreve o seu .env.

# Porta do Vite (npm run dev)
VITE_DEV_PORT=5173

# Porta usada pelo Playwright (npm run test:e2e)
PLAYWRIGHT_PORT=5173

# Opcional: URL do backend se no futuro sair do proxy fixo em vite.config.ts
# VITE_API_BASE_URL=http://127.0.0.1:8000
